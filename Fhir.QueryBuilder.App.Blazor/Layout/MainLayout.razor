@inherits LayoutComponentBase

<div class="page">
    <main class="content px-3 pb-4">
        @Body
    </main>

    <footer class="qb-footer border-top py-2 px-3">
        <div class="container-fluid">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                <div class="d-flex align-items-center gap-3">
                    <img src="images/ITRI_logo.jpg"
                         alt="工業技術研究院 Industrial Technology Research Institute"
                         class="qb-footer-logo" />
                    <div class="small text-muted">
                        <div>&copy; @DateTime.Now.Year 工業技術研究院（ITRI）。版權所有。</div>
                        <div>FHIR Query Builder</div>
                    </div>
                </div>
                <div class="small text-muted text-md-end">
                    <div>聯絡人：范士展（Fan Shih-Chan）</div>
                    <div>
                        <a href="mailto:sjvann@itri.org.tw" class="text-decoration-none">
                            sjvann@itri.org.tw
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </footer>
</div>
