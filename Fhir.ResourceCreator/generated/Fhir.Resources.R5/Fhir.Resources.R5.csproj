    <RootNamespace>Fhir.Resources.R5</RootNamespace>
    <AssemblyName>Fhir.Resources.R5</AssemblyName>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <PackageId>Fhir.Resources.R5</PackageId>
