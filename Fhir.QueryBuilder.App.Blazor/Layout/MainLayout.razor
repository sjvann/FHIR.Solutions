@inherits LayoutComponentBase
@inject QueryBuilderUiLanguageService UiLang
@inject IJSRuntime Js
@implements IDisposable

<div class="page">
    <main class="content px-3 pb-4">
        @Body
    </main>

    <footer class="qb-footer border-top py-2 px-3">
        <div class="container-fluid">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                <div class="d-flex align-items-center gap-3">
                    <img src="images/ITRI_logo.jpg"
                         alt="@UiLang.Strings.FooterAltItriLogo"
                         class="qb-footer-logo" />
                    <div class="small text-muted">
                        <div>@string.Format(UiLang.Strings.CopyrightLineFormat, DateTime.Now.Year)</div>
                        <div>@UiLang.Strings.AppTitleShort</div>
                    </div>
                </div>
                <div class="small text-muted text-md-end">
                    <div>@UiLang.Strings.ContactNameLine</div>
                    <div>
                        <a href="mailto:sjvann@itri.org.tw" class="text-decoration-none">
                            sjvann@itri.org.tw
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </footer>
</div>

@code {
    protected override void OnInitialized() => UiLang.Changed += OnUiLangChanged;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await UiLang.TryLoadFromBrowserAsync(Js).ConfigureAwait(false);
            await InvokeAsync(StateHasChanged).ConfigureAwait(false);
        }
    }

    private void OnUiLangChanged() => _ = InvokeAsync(StateHasChanged);

    public void Dispose() => UiLang.Changed -= OnUiLangChanged;
}
