<Window xmlns="https://github.com/avaloniaui"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        xmlns:vm="using:Fhir.QueryBuilder.ViewModels"

        xmlns:models="using:Fhir.QueryBuilder.Models"

        xmlns:v="using:Fhir.QueryBuilder.App.Avalonia.Views"

        xmlns:searchUi="using:Fhir.QueryBuilder.SearchUi"

        x:Class="Fhir.QueryBuilder.App.Avalonia.MainWindow"

        x:DataType="vm:MainViewModel"

        Title="{Binding UiStrings.AppTitleShort}"

        Icon="avares://Fhir.QueryBuilder.App.Avalonia/Assets/favicon.png"

        Width="1180"

        Height="820"

        MinWidth="920"

        MinHeight="680"

        FontFamily="Segoe UI, Inter, ui-sans-serif, system-ui">

    <Window.Styles>

        <Style Selector="TextBlock.sectionTitle">

            <Setter Property="FontSize" Value="13" />

            <Setter Property="FontWeight" Value="SemiBold" />

            <Setter Property="VerticalAlignment" Value="Center" />

        </Style>

        <Style Selector="Border.card">

            <Setter Property="Padding" Value="14" />

            <Setter Property="CornerRadius" Value="10" />

            <Setter Property="BorderThickness" Value="1" />

            <Setter Property="BorderBrush" Value="{DynamicResource DividerStrokeColorDefaultBrush}" />

        </Style>

        <Style Selector="Border.block">

            <Setter Property="Padding" Value="10" />

            <Setter Property="CornerRadius" Value="8" />

            <Setter Property="BorderThickness" Value="1" />

            <Setter Property="BorderBrush" Value="{DynamicResource DividerStrokeColorDefaultBrush}" />

            <Setter Property="ClipToBounds" Value="True" />

        </Style>

        <Style Selector="TabControl.queryTabs TabItem">

            <Setter Property="FontSize" Value="12.5" />

            <Setter Property="Padding" Value="8,7,10,7" />

            <Setter Property="Margin" Value="0,0,5,0" />

        </Style>

        <!-- Tab 內容區與標籤列左緣對齊（Fluent 預設 ContentPresenter 常有水平留白） -->
        <Style Selector="TabControl.queryTabs TabItem /template/ ContentPresenter">

            <Setter Property="Margin" Value="0" />

            <Setter Property="Padding" Value="0" />

        </Style>

        <Style Selector="TabControl.queryTabs TabItem:selected">

            <Setter Property="FontWeight" Value="SemiBold" />

            <Setter Property="Opacity" Value="1" />

        </Style>

        <Style Selector="TabControl.queryTabs TabItem:not(:selected)">

            <Setter Property="Opacity" Value="0.78" />

        </Style>

        <Style Selector="TabControl.queryTabs">

            <Setter Property="Padding" Value="0,2,0,0" />

        </Style>

    </Window.Styles>



    <Grid Margin="20" RowDefinitions="Auto,Auto,Auto,*,Auto,Auto">

        <Border Grid.Row="0" Classes="card">

            <StackPanel Spacing="10">

                <Grid ColumnDefinitions="2*,Auto,Auto,*">

                    <TextBox Grid.Column="0"

                             Watermark="{Binding UiStrings.FhirBaseUrlPlaceholder}"

                             Text="{Binding ServerUrl}"

                             VerticalAlignment="Center"

                             MinHeight="34" />

                    <Button Grid.Column="1"

                            Margin="12,0,0,0"

                            Content="{Binding UiStrings.Connect}"

                            Classes="accent"

                            Command="{Binding ConnectToServerCommand}"

                            IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}" />

                    <Button Grid.Column="2"

                            Margin="8,0,0,0"

                            Content="{Binding UiStrings.Cancel}"

                            Command="{Binding CancelOperationCommand}"

                            IsEnabled="{Binding IsLoading}" />

                    <Grid Grid.Column="3"

                          Margin="16,0,0,0"

                          ColumnDefinitions="Auto,*"

                          MinWidth="180">

                        <TextBlock Grid.Column="0"

                                   Classes="sectionTitle"

                                   Text="{Binding UiStrings.ResourceType}"

                                   VerticalAlignment="Center"

                                   Margin="0,0,10,0" />

                        <AutoCompleteBox Grid.Column="1"

                                         MinHeight="34"

                                         HorizontalAlignment="Stretch"

                                         VerticalAlignment="Center"

                                         Watermark="{Binding UiStrings.ResourceTypeAutocompleteWatermark}"

                                         ItemsSource="{Binding SupportedResources}"

                                         SelectedItem="{Binding SelectedResource, Mode=TwoWay}"

                                         FilterMode="StartsWith"

                                         MinimumPrefixLength="1"

                                         SelectionChanged="ResourceAutoComplete_OnSelectionChanged"

                                         LostFocus="ResourceAutoComplete_OnLostFocus" />

                    </Grid>

                </Grid>

                <DockPanel LastChildFill="True">

                    <StackPanel DockPanel.Dock="Right"

                                Orientation="Horizontal"

                                Spacing="8"

                                VerticalAlignment="Center">

                        <TextBlock Text="{Binding UiStrings.Language}"

                                   VerticalAlignment="Center"

                                   Opacity="0.85" />

                        <ComboBox x:Name="UiLanguageCombo"

                                  Width="128"

                                  MinHeight="32"

                                  VerticalAlignment="Center"

                                  SelectionChanged="UiLanguageCombo_OnSelectionChanged">

                            <ComboBoxItem Tag="zh-TW" Content="繁體中文" />

                            <ComboBoxItem Tag="zh-CN" Content="简体中文" />

                            <ComboBoxItem Tag="en" Content="English" />

                            <ComboBoxItem Tag="ja" Content="日本語" />

                            <ComboBoxItem Tag="ko" Content="한국어" />

                        </ComboBox>

                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">

                    <TextBlock Text="{Binding UiStrings.FhirDeclaration}" VerticalAlignment="Center" />

                    <ComboBox Width="92"

                              MinHeight="34"

                              VerticalAlignment="Center"

                              ItemsSource="{Binding FhirVersionChoices}"

                              SelectedItem="{Binding SelectedFhirVersionShort, Mode=TwoWay}" />

                    <TextBlock Text="{Binding UiStrings.Detected}" VerticalAlignment="Center" Opacity="0.75" />

                    <TextBlock Text="{Binding DetectedFhirVersionDisplay}"

                               VerticalAlignment="Center"

                               FontWeight="SemiBold" />

                    <TextBlock Text="{Binding UiStrings.Active}" VerticalAlignment="Center" Opacity="0.75" />

                    <TextBlock Text="{Binding ActiveFhirVersionDisplay}"

                               VerticalAlignment="Center"

                               FontWeight="SemiBold" />

                    </StackPanel>

                </DockPanel>

                <TextBox Watermark="{Binding UiStrings.BearerTokenAvaloniaWatermark}"

                         Text="{Binding BearerAccessToken}"

                         PasswordChar="*"

                         MinHeight="34" />

                <StackPanel IsVisible="{Binding SupportOAuth}" Orientation="Vertical" Spacing="8">

                    <TextBlock FontSize="12"

                               FontWeight="SemiBold"

                               Opacity="0.9"

                               TextWrapping="Wrap"

                               Text="{Binding UiStrings.SmartOnFhir}" />

                    <Grid ColumnDefinitions="Auto,*">

                        <TextBlock Grid.Column="0"

                                   Margin="0,0,8,0"

                                   VerticalAlignment="Center"

                                   Text="{Binding UiStrings.ClientId}" />

                        <TextBox Grid.Column="1"

                                 Watermark="{Binding UiStrings.SmartClientIdWatermark}"

                                 Text="{Binding SmartClientId}"

                                 MinHeight="34" />

                    </Grid>

                    <TextBox Watermark="{Binding UiStrings.SmartScopesWatermark}"

                             Text="{Binding SmartScopes}"

                             AcceptsReturn="True"

                             TextWrapping="Wrap"

                             MinHeight="48" />

                    <TextBox Watermark="{Binding UiStrings.SmartPrivateKeyPemWatermark}"

                             Text="{Binding SmartPrivateKeyPem}"

                             AcceptsReturn="True"

                             TextWrapping="Wrap"

                             FontFamily="Consolas,Courier New,monospace"

                             MinHeight="72" />

                    <TextBlock FontSize="11"

                               Opacity="0.75"

                               TextWrapping="Wrap"

                               Text="{Binding SmartPatientSummary}" />

                    <WrapPanel Orientation="Horizontal">

                        <Button Margin="0,0,8,8"

                                Content="{Binding UiStrings.SmartLoginPkce}"

                                Command="{Binding RunSmartBrowserLoginCommand}"

                                IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}" />

                        <Button Margin="0,0,8,8"

                                Content="{Binding UiStrings.RefreshAccessToken}"

                                Command="{Binding RefreshSmartTokenCommand}"

                                IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}" />

                        <Button Margin="0,0,8,8"

                                Content="{Binding UiStrings.JwtClientCredentials}"

                                Command="{Binding RunSmartClientCredentialsJwtCommand}"

                                IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}" />

                        <Button Margin="0,0,8,8"

                                Content="{Binding UiStrings.ClearSmartSession}"

                                Command="{Binding ClearSmartSessionCommand}"

                                IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}" />

                        <Button Margin="0,0,8,8" Content="{Binding UiStrings.OpenAuthorizeUrl}" Command="{Binding OpenAuthorizeUrlCommand}" />

                        <Button Margin="0,0,8,8" Content="{Binding UiStrings.OpenTokenUrl}" Command="{Binding OpenTokenUrlCommand}" />

                        <Button Margin="0,0,8,8" Content="{Binding UiStrings.CopyTokenUrl}" Command="{Binding CopyTokenUrlCommand}" />

                    </WrapPanel>

                    <TextBlock FontSize="10"

                               Opacity="0.65"

                               TextWrapping="Wrap"

                               Text="{Binding TokenUrl}" />

                </StackPanel>

            </StackPanel>

        </Border>



        <Border Grid.Row="1"

                Margin="0,8,0,0"

                Classes="card"

                IsVisible="{Binding HasValidationErrors}">

            <Grid ColumnDefinitions="*,Auto">

                <ItemsControl Grid.Column="0" ItemsSource="{Binding ValidationErrors}">

                    <ItemsControl.ItemTemplate>

                        <DataTemplate>

                            <TextBlock Margin="0,2"

                                       Foreground="#c05000"

                                       TextWrapping="Wrap"

                                       Text="{Binding}" />

                        </DataTemplate>

                    </ItemsControl.ItemTemplate>

                </ItemsControl>

                <Button Grid.Column="1"

                        Margin="12,0,0,0"

                        VerticalAlignment="Top"

                        Content="{Binding UiStrings.Clear}"

                        Command="{Binding ClearValidationErrorsCommand}" />

            </Grid>

        </Border>



        <Border Grid.Row="2"

                Margin="0,2,0,0"

                Padding="8"

                Classes="card">

            <Grid ColumnDefinitions="*,Auto,Auto,Auto">

                <TextBox Grid.Column="0"

                         Watermark="{Binding UiStrings.FullQueryUrlBuiltBelow}"

                         Text="{Binding QueryUrl}"

                         MinHeight="38"

                         VerticalAlignment="Center" />

                <Button Grid.Column="1"

                        Margin="12,0,0,0"

                        VerticalAlignment="Center"

                        Content="{Binding UiStrings.BuildComposedUrl}"

                        Command="{Binding BuildComposedQueryCommand}"

                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}" />

                <Button Grid.Column="2"

                        Margin="8,0,0,0"

                        VerticalAlignment="Center"

                        Classes="accent"

                        Content="{Binding UiStrings.ExecuteQuery}"

                        Command="{Binding ExecuteQueryCommand}"

                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}" />

                <Button Grid.Column="3"

                        Margin="8,0,0,0"

                        VerticalAlignment="Center"

                        Content="{Binding UiStrings.ClearUrl}"

                        Command="{Binding ClearQueryUrlFieldCommand}"

                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}" />

            </Grid>

        </Border>



        <Grid Grid.Row="3"

              Margin="0,2,0,0"

              ColumnDefinitions="1.38*,1.18*,1.38*">

            <Border Grid.Column="0"

                    Margin="0,0,1,0"

                    Padding="8"

                    Classes="card"

                    MinWidth="220">

                <TabControl Classes="queryTabs"

                            MinHeight="360">

                    <TabItem Header="{Binding UiStrings.TabSearchParameters}">

                        <Grid Margin="0,4,4,4">

                            <Border Classes="block"

                                    MinHeight="220"

                                    Padding="2,8,8,8">

                                <Grid ColumnDefinitions="*,*"

                                      RowDefinitions="*">

                                    <Border Grid.Column="0"

                                            Classes="block"

                                            Padding="6,8,8,8">

                                        <DockPanel LastChildFill="True">

                                            <TextBlock DockPanel.Dock="Top"

                                                       Margin="0,0,0,8"

                                                       Text="{Binding UiStrings.CapabilitySearchParams}"

                                                       FontWeight="SemiBold" />

                                            <ScrollViewer VerticalScrollBarVisibility="Auto"

                                                          HorizontalScrollBarVisibility="Disabled">

                                                <ListBox ItemsSource="{Binding SearchParameters}"

                                                         SelectedItem="{Binding SelectedSearchParameter}">

                                                    <ListBox.Styles>

                                                        <Style Selector="ListBoxItem">

                                                            <Setter Property="Padding" Value="6,1" />

                                                            <Setter Property="MinHeight" Value="0" />

                                                        </Style>

                                                    </ListBox.Styles>

                                                    <ListBox.ItemTemplate>

                                                        <DataTemplate DataType="models:SearchParamModel">

                                                            <TextBlock Text="{Binding DisplayText}"

                                                                       VerticalAlignment="Center" />

                                                        </DataTemplate>

                                                    </ListBox.ItemTemplate>

                                                </ListBox>

                                            </ScrollViewer>

                                        </DockPanel>

                                    </Border>

                                    <Border Grid.Column="1"

                                            Margin="4,0,0,0"

                                            Classes="block"

                                            Padding="8">

                                        <Grid RowDefinitions="Auto,*">

                                            <TextBlock Grid.Row="0"

                                                       Margin="0,0,0,8"

                                                       Text="{Binding UiStrings.TypedBuilderSection}"

                                                       FontWeight="SemiBold"

                                                       TextWrapping="Wrap" />

                                            <v:TypedSearchTab Grid.Row="1" />

                                        </Grid>

                                    </Border>

                                </Grid>

                            </Border>

                        </Grid>

                    </TabItem>

                    <TabItem Header="{Binding UiStrings.TabAdvanced}">

                        <v:AdvancedSearchTab />

                    </TabItem>

                    <TabItem Header="{Binding UiStrings.TabModifyingResults}">

                        <v:ModifyingSearchTab />

                    </TabItem>

                </TabControl>

            </Border>

            <Border Grid.Column="1"

                    Margin="0,0,1,0"

                    Padding="8"

                    Classes="card"

                    MinWidth="140">

                <Grid RowDefinitions="*,*">

                    <DockPanel Grid.Row="0">

                        <TextBlock DockPanel.Dock="Top"

                                   Text="{Binding UiStrings.CardDraftQueryLines}"

                                   FontWeight="SemiBold"

                                   Margin="0,0,0,6" />

                        <StackPanel DockPanel.Dock="Bottom"

                                    Orientation="Horizontal"

                                    Spacing="8"

                                    Margin="0,8,0,0">

                            <Button Content="{Binding UiStrings.RemoveSelected}"

                                    Command="{Binding RemoveSelectedDraftFromListCommand}" />

                            <Button Content="{Binding UiStrings.ClearAll}"

                                    Command="{Binding ClearAllDraftSearchParametersCommand}" />

                        </StackPanel>

                        <ListBox MinHeight="72"

                                 ItemsSource="{Binding DraftSearchParameters}"

                                 SelectedItem="{Binding SelectedDraftParameter}" />

                    </DockPanel>

                    <TabControl Grid.Row="1"

                                Margin="0,6,0,0"

                                Classes="queryTabs"

                                MinHeight="140">

                        <TabItem Header="{Binding UiStrings.TabInclude}">

                            <ScrollViewer HorizontalScrollBarVisibility="Disabled"

                                          VerticalScrollBarVisibility="Auto">

                                <StackPanel Margin="8"

                                            Spacing="10">

                                    <CheckBox Content="{Binding UiStrings.EmitEveryListedPath}"

                                              IsChecked="{Binding IncludeTakeAll}" />

                                    <ItemsControl ItemsSource="{Binding IncludeChoices}">

                                        <ItemsControl.ItemTemplate>

                                            <DataTemplate DataType="models:SelectableIncludeRow">

                                                <CheckBox Margin="0,3"

                                                          Content="{Binding Value}"

                                                          IsChecked="{Binding IsSelected, Mode=TwoWay}" />

                                            </DataTemplate>

                                        </ItemsControl.ItemTemplate>

                                    </ItemsControl>

                                </StackPanel>

                            </ScrollViewer>

                        </TabItem>

                        <TabItem Header="{Binding UiStrings.TabRevInclude}">

                            <ScrollViewer HorizontalScrollBarVisibility="Disabled"

                                          VerticalScrollBarVisibility="Auto">

                                <StackPanel Margin="8"

                                            Spacing="10">

                                    <CheckBox Content="{Binding UiStrings.EmitEveryListedPath}"

                                              IsChecked="{Binding RevIncludeTakeAll}" />

                                    <ItemsControl ItemsSource="{Binding RevIncludeChoices}">

                                        <ItemsControl.ItemTemplate>

                                            <DataTemplate DataType="models:SelectableIncludeRow">

                                                <CheckBox Margin="0,3"

                                                          Content="{Binding Value}"

                                                          IsChecked="{Binding IsSelected, Mode=TwoWay}" />

                                            </DataTemplate>

                                        </ItemsControl.ItemTemplate>

                                    </ItemsControl>

                                </StackPanel>

                            </ScrollViewer>

                        </TabItem>

                    </TabControl>

                </Grid>

            </Border>

            <Border Grid.Column="2"

                    Margin="1,0,0,0"

                    Padding="8"

                    Classes="card"

                    MinWidth="240">

                <Grid RowDefinitions="*,Auto">

                    <Border Grid.Row="0"

                            Padding="4"

                            CornerRadius="6"

                            BorderThickness="1"

                            BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"

                            MinHeight="280">

                        <Grid>

                            <TreeView VerticalAlignment="Stretch"

                                      MinHeight="240"

                                      IsVisible="{Binding ShowQueryResultAsTree}"

                                      ItemsSource="{Binding QueryResultTreeRoots}">

                                <TreeView.ItemTemplate>

                                    <TreeDataTemplate DataType="searchUi:JsonTreeItem"

                                                      ItemsSource="{Binding Children}">

                                        <TextBlock Text="{Binding Header}" />

                                    </TreeDataTemplate>

                                </TreeView.ItemTemplate>

                            </TreeView>

                            <TextBox AcceptsReturn="True"

                                     TextWrapping="Wrap"

                                     Watermark="{Binding UiStrings.JsonPlaceholder}"

                                     Text="{Binding QueryResult}"

                                     VerticalAlignment="Stretch"

                                     VerticalContentAlignment="Top"

                                     FontFamily="Consolas,Courier New,monospace"

                                     IsVisible="{Binding ShowQueryResultAsTree, Converter={StaticResource InverseBool}}" />

                        </Grid>

                    </Border>



                    <DockPanel Grid.Row="1"

                               Margin="0,6,0,0"

                               LastChildFill="False">

                        <Button DockPanel.Dock="Right"

                                Margin="12,0,0,0"

                                Content="{Binding UiStrings.Exit}"

                                Click="Exit_OnClick" />

                        <WrapPanel Orientation="Horizontal">

                            <Button Margin="0,0,8,8"

                                    Content="{Binding UiStrings.Copy}"

                                    Command="{Binding CopyQueryResultCommand}"

                                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}" />

                            <Button Margin="0,0,8,8"

                                    Content="{Binding UiStrings.Save}"

                                    Command="{Binding SaveQueryResultCommand}"

                                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}" />

                            <Button Margin="0,0,8,8"

                                    Content="{Binding UiStrings.Clear}"

                                    Command="{Binding ClearQueryResultFieldCommand}"

                                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}" />

                            <Button Margin="0,0,8,8"

                                    Content="{Binding ResultViewToggleLabel}"

                                    Command="{Binding ToggleQueryResultTreeCommand}"

                                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}" />

                        </WrapPanel>

                    </DockPanel>

                </Grid>

            </Border>

        </Grid>



        <TextBlock Grid.Row="4"

                   Margin="0,4,0,0"

                   Text="{Binding StatusMessage}"

                   TextWrapping="Wrap"

                   FontSize="11"

                   LineHeight="16"

                   Opacity="0.85" />

        <Border Grid.Row="5"

                Margin="0,10,0,0"

                Padding="12,8"

                CornerRadius="6"

                BorderThickness="1,1,1,1"

                BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}">

            <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">

                <Image Grid.Column="0"

                       Margin="0,0,2,0"

                       Source="avares://Fhir.QueryBuilder.App.Avalonia/Assets/ITRI_logo.jpg"

                       Height="36"

                       MaxHeight="40"

                       MaxWidth="220"

                       Stretch="Uniform"

                       VerticalAlignment="Center" />

                <StackPanel Grid.Column="1"

                            Margin="10,0,0,0"

                            VerticalAlignment="Center"

                            Spacing="2">

                    <TextBlock FontSize="11"

                               Opacity="0.85"

                               Text="{Binding FooterCopyrightText}" />

                    <StackPanel Orientation="Horizontal"

                                Spacing="6"

                                VerticalAlignment="Center">

                        <Image Height="18"

                               Width="18"

                               Stretch="Uniform"

                               VerticalAlignment="Center"

                               Source="avares://Fhir.QueryBuilder.App.Avalonia/Assets/favicon.png" />

                        <TextBlock FontSize="11"

                                   Opacity="0.7"

                                   VerticalAlignment="Center"

                                   Text="{Binding UiStrings.AppTitleShort}" />

                    </StackPanel>

                </StackPanel>

                <StackPanel Grid.Column="2"

                            VerticalAlignment="Center"

                            HorizontalAlignment="Right"

                            Spacing="2">

                    <TextBlock FontSize="11"

                               Opacity="0.85"

                               TextAlignment="Right"

                               Text="{Binding UiStrings.ContactNameLine}" />

                    <TextBlock FontSize="11"

                               Opacity="0.85"

                               TextAlignment="Right"

                               Text="sjvann@itri.org.tw" />

                </StackPanel>

            </Grid>

        </Border>

    </Grid>

</Window>


