<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Fhir.QueryBuilder.ViewModels"
             x:Class="Fhir.QueryBuilder.App.Avalonia.Views.ModifyingSearchTab"
             x:DataType="vm:MainViewModel">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10" Spacing="14">
            <TextBlock FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       Text="結果修飾參數" />

            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Margin="0,0,12,8"
                           VerticalAlignment="Center"
                           Text="_contained" />
                <ComboBox Grid.Row="0" Grid.Column="1"
                          MinWidth="200"
                          Margin="0,0,0,8"
                          ItemsSource="{Binding Modifying.ContainedPresetChoices}"
                          SelectedItem="{Binding Modifying.ContainedChoice}" />

                <TextBlock Grid.Row="1" Grid.Column="0"
                           Margin="0,0,12,8"
                           VerticalAlignment="Center"
                           Text="_containedType" />
                <ComboBox Grid.Row="1" Grid.Column="1"
                          Margin="0,0,0,8"
                          ItemsSource="{Binding Modifying.ContainedTypePresetChoices}"
                          SelectedItem="{Binding Modifying.ContainedTypeChoice}" />

                <TextBlock Grid.Row="2" Grid.Column="0"
                           Margin="0,0,12,8"
                           VerticalAlignment="Center"
                           Text="_count" />
                <TextBox Grid.Row="2" Grid.Column="1"
                         Margin="0,0,0,8"
                         Watermark="分頁筆數"
                         Text="{Binding Modifying.CountValue}" />

                <TextBlock Grid.Row="3" Grid.Column="0"
                           Margin="0,0,12,8"
                           VerticalAlignment="Center"
                           Text="_maxresults" />
                <TextBox Grid.Row="3" Grid.Column="1"
                         Margin="0,0,0,8"
                         Watermark="Bundle 內最大筆數"
                         Text="{Binding Modifying.MaxResultsValue}" />

                <TextBlock Grid.Row="4" Grid.Column="0"
                           Margin="0,0,12,0"
                           VerticalAlignment="Center"
                           Text="_summary" />
                <ComboBox Grid.Row="4" Grid.Column="1"
                          ItemsSource="{Binding Modifying.SummaryPresetChoices}"
                          SelectedItem="{Binding Modifying.SummaryChoice}" />
            </Grid>

            <Separator />

            <TextBlock FontWeight="SemiBold" Text="_elements／_sort" />
            <Grid RowDefinitions="Auto,Auto">
                <ComboBox Grid.Row="0"
                          HorizontalAlignment="Stretch"
                          MinWidth="200"
                          Margin="0,0,0,8"
                          ItemsSource="{Binding Modifying.ElementChoices}"
                          SelectedItem="{Binding Modifying.SelectedElementHint}" />
                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            Spacing="12">
                    <CheckBox VerticalAlignment="Center"
                              Margin="0,0,4,0"
                              Content="Sort 前綴「-」"
                              IsChecked="{Binding Modifying.SortDescendingPrefix}" />
                    <Button VerticalAlignment="Center"
                            Content="加入 Elements"
                            Command="{Binding ModifyingAddElementCommand}" />
                    <Button VerticalAlignment="Center"
                            Content="加入 Sort"
                            Command="{Binding ModifyingAddSortCommand}" />
                </StackPanel>
            </Grid>

            <Grid ColumnDefinitions="*,*">
                <StackPanel Grid.Column="0"
                            Margin="0,0,6,0"
                            Spacing="8">
                    <TextBlock FontSize="12" Opacity="0.8" Text="Elements 列表" />
                    <ListBox MinHeight="80"
                             MaxHeight="160"
                             ItemsSource="{Binding Modifying.Elements}" />
                    <Button HorizontalAlignment="Stretch"
                            Content="清空 Elements"
                            Command="{Binding ModifyingClearElementsCommand}" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Margin="6,0,0,0"
                            Spacing="8">
                    <TextBlock FontSize="12" Opacity="0.8" Text="Sort 列表" />
                    <ListBox MinHeight="80"
                             MaxHeight="160"
                             ItemsSource="{Binding Modifying.SortLines}" />
                    <Button HorizontalAlignment="Stretch"
                            Content="清空 Sort"
                            Command="{Binding ModifyingClearSortCommand}" />
                </StackPanel>
            </Grid>

            <Button HorizontalAlignment="Left"
                    Content="重設本頁"
                    Command="{Binding ModifyingResetFormCommand}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
