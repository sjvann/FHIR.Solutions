@inject MainViewModel Vm
@inject QueryBuilderUiLanguageService Lang

<div class="small typed-search-panel min-w-0 overflow-x-hidden">
    <p class="fw-semibold mb-2 d-flex align-items-center flex-wrap gap-1">
        <span>@Lang.Strings.SelectedLabel</span>
        <span class="text-muted">@(Vm.SelectedSearchParameter?.DisplayText ?? Lang.Strings.SelectedNone)</span>
        @if (Vm.HasSearchParameterDocumentation)
        {
            <abbr class="text-secondary small user-select-none"
                  title="@Vm.SearchParameterDocumentation"
                  style="cursor: help;">ⓘ</abbr>
        }
    </p>

    @if (Vm.EditorUnsupportedVisible)
    {
        <p class="text-secondary">@Lang.Strings.EditorUnsupported</p>
    }

    @if (Vm.EditorStringVisible)
    {
        <div class="border rounded p-2 mb-3">
            <div class="fw-semibold mb-2">@Lang.Strings.String</div>
            <input class="form-control form-control-sm mb-2" placeholder="@Lang.Strings.ModifierLabel"
                   @bind="Vm.TypedSearch.StringGroupModifier" @bind:event="oninput" />
            <input class="form-control form-control-sm" placeholder="@Lang.Strings.Value"
                   @bind="Vm.TypedSearch.StringValue" @bind:event="oninput" />
        </div>
    }

    @if (Vm.EditorTokenVisible)
    {
        <div class="border rounded p-2 mb-3">
            <div class="fw-semibold mb-2">@Lang.Strings.Token</div>
            <input class="form-control form-control-sm mb-2" placeholder="@Lang.Strings.Modifier"
                   @bind="Vm.TypedSearch.TokenGroupModifier" @bind:event="oninput" />
            <input class="form-control form-control-sm mb-2" placeholder="@Lang.Strings.CodeOnly"
                   @bind="Vm.TypedSearch.TokenCodeOnly" @bind:event="oninput" />
            <input class="form-control form-control-sm mb-2" placeholder="@Lang.Strings.SystemLabel"
                   @bind="Vm.TypedSearch.TokenSystem" @bind:event="oninput" />
            <input class="form-control form-control-sm" placeholder="@Lang.Strings.CodeWithSystem"
                   @bind="Vm.TypedSearch.TokenCodeWithSystem" @bind:event="oninput" />
        </div>
    }

    @if (Vm.EditorUriVisible)
    {
        <div class="border rounded p-2 mb-3">
            <div class="fw-semibold mb-2">@Lang.Strings.Uri</div>
            <input class="form-control form-control-sm mb-2" placeholder="@Lang.Strings.Modifier"
                   @bind="Vm.TypedSearch.UriGroupModifier" @bind:event="oninput" />
            <input class="form-control form-control-sm" placeholder="@Lang.Strings.UriValue"
                   @bind="Vm.TypedSearch.UriText" @bind:event="oninput" />
        </div>
    }

    @if (Vm.EditorReferenceVisible)
    {
        <div class="border rounded p-2 mb-3">
            <div class="fw-semibold mb-2">@Lang.Strings.Reference</div>
            <input class="form-control form-control-sm mb-2" placeholder="@Lang.Strings.Modifier"
                   @bind="Vm.TypedSearch.ReferenceGroupModifier" @bind:event="oninput" />
            <div class="row g-2">
                <div class="col-md-6"><input class="form-control form-control-sm" placeholder="@Lang.Strings.LogicalId" @bind="Vm.TypedSearch.ReferenceId" @bind:event="oninput" /></div>
                <div class="col-md-6"><input class="form-control form-control-sm" placeholder="@Lang.Strings.Version" @bind="Vm.TypedSearch.ReferenceVersion" @bind:event="oninput" /></div>
                <div class="col-md-6"><input class="form-control form-control-sm" placeholder="@Lang.Strings.ResourceTypePh" @bind="Vm.TypedSearch.ReferenceType" @bind:event="oninput" /></div>
                <div class="col-md-6"><input class="form-control form-control-sm" placeholder="@Lang.Strings.LogicalIdTypeSlash" @bind="Vm.TypedSearch.ReferenceTypeId" @bind:event="oninput" /></div>
            </div>
            <input class="form-control form-control-sm mt-2" placeholder="@Lang.Strings.CanonicalUrlPlaceholder"
                   @bind="Vm.TypedSearch.ReferenceUrl" @bind:event="oninput" />
        </div>
    }

    @if (Vm.EditorNumberVisible)
    {
        <div class="border rounded p-2 mb-3">
            <div class="fw-semibold mb-2">@Lang.Strings.Number</div>
            <input class="form-control form-control-sm mb-2" placeholder="@Lang.Strings.Modifier"
                   @bind="Vm.TypedSearch.NumberGroupModifier" @bind:event="oninput" />
            <select class="form-select form-select-sm mb-2" @bind="Vm.TypedSearch.NumberPrefix">
                <option value="">@Lang.Strings.PrefixOption</option>
                @foreach (var p in Vm.NumberSearchPrefixes)
                {
                    <option value="@p">@p</option>
                }
            </select>
            <input class="form-control form-control-sm" placeholder="@Lang.Strings.Value"
                   @bind="Vm.TypedSearch.NumberValue" @bind:event="oninput" />
        </div>
    }

    @if (Vm.EditorDateVisible)
    {
        <div class="border rounded p-2 mb-3">
            <div class="fw-semibold mb-2">@Lang.Strings.Date</div>
            <input class="form-control form-control-sm mb-2" placeholder="@Lang.Strings.Modifier"
                   @bind="Vm.TypedSearch.DateGroupModifier" @bind:event="oninput" />
            <select class="form-select form-select-sm mb-2" @bind="Vm.TypedSearch.DatePrefix">
                <option value="">@Lang.Strings.PrefixOption</option>
                @foreach (var p in Vm.DateSearchPrefixes)
                {
                    <option value="@p">@p</option>
                }
            </select>
            <input class="form-control form-control-sm" placeholder="@Lang.Strings.Value"
                   @bind="Vm.TypedSearch.DateValue" @bind:event="oninput" />
        </div>
    }

    @if (Vm.EditorQuantityVisible)
    {
        <div class="border rounded p-2 mb-3">
            <div class="fw-semibold mb-2">@Lang.Strings.Quantity</div>
            <input class="form-control form-control-sm mb-2" placeholder="@Lang.Strings.Modifier"
                   @bind="Vm.TypedSearch.QuantityGroupModifier" @bind:event="oninput" />
            <select class="form-select form-select-sm mb-2" @bind="Vm.TypedSearch.QuantityPrefix">
                <option value="">@Lang.Strings.PrefixOption</option>
                @foreach (var p in Vm.QuantitySearchPrefixes)
                {
                    <option value="@p">@p</option>
                }
            </select>
            <input class="form-control form-control-sm mb-2" placeholder="@Lang.Strings.DecimalNumber"
                   @bind="Vm.TypedSearch.QuantityNumber" @bind:event="oninput" />
            <div class="text-secondary small mb-1">@Lang.Strings.OrCodedQuantity</div>
            <input class="form-control form-control-sm mb-2" placeholder="@Lang.Strings.ValueNumberPlaceholder"
                   @bind="Vm.TypedSearch.QuantityNscNumber" @bind:event="oninput" />
            <input class="form-control form-control-sm mb-2" placeholder="@Lang.Strings.SystemLabel"
                   @bind="Vm.TypedSearch.QuantityNscSystem" @bind:event="oninput" />
            <input class="form-control form-control-sm" placeholder="@Lang.Strings.Code"
                   @bind="Vm.TypedSearch.QuantityNscCode" @bind:event="oninput" />
        </div>
    }

    @if (Vm.EditorCompositeVisible)
    {
        <div class="border rounded p-2 mb-3" @key="Vm.CompositePartRowsRevision">
            <div class="fw-semibold mb-2">@Lang.Strings.Composite</div>
            @if (Vm.CompositeRichRowsVisible)
            {
                <p class="text-secondary small mb-2">
                    @(Vm.CompositeMetadataLoadedFromServer
                        ? Lang.Strings.CompositeMetadataFromServer
                        : Lang.Strings.CompositeLocalBlocks)
                </p>
                @foreach (var row in Vm.TypedSearch.CompositePartRows)
                {
                    <div class="border rounded p-2 mb-2 bg-body-secondary bg-opacity-10">
                        <div class="fw-semibold small mb-2">@row.Label</div>
                        @if (row.IsTokenComponent)
                        {
                            <input class="form-control form-control-sm mb-2" placeholder="@Lang.Strings.CodeOnly"
                                   @bind="row.TokenCodeOnly" @bind:event="oninput" />
                            <input class="form-control form-control-sm mb-2" placeholder="@Lang.Strings.SystemLabel"
                                   @bind="row.TokenSystem" @bind:event="oninput" />
                            <input class="form-control form-control-sm mb-2" placeholder="@Lang.Strings.CodeWithSystem"
                                   @bind="row.TokenCodeWithSystem" @bind:event="oninput" />
                        }
                        else if (row.IsQuantityComponent)
                        {
                            <select class="form-select form-select-sm mb-2" @bind="row.QuantityPrefix">
                                <option value="">@Lang.Strings.PrefixOption</option>
                                @foreach (var p in Vm.QuantitySearchPrefixes)
                                {
                                    <option value="@p">@p</option>
                                }
                            </select>
                            <input class="form-control form-control-sm mb-2" placeholder="@Lang.Strings.DecimalNumber"
                                   @bind="row.QuantityNumber" @bind:event="oninput" />
                            <div class="text-secondary small mb-1">@Lang.Strings.OrCodedQuantity</div>
                            <input class="form-control form-control-sm mb-2" placeholder="@Lang.Strings.ValueNumberPlaceholder"
                                   @bind="row.QuantityNscNumber" @bind:event="oninput" />
                            <input class="form-control form-control-sm mb-2" placeholder="@Lang.Strings.SystemLabel"
                                   @bind="row.QuantityNscSystem" @bind:event="oninput" />
                            <input class="form-control form-control-sm" placeholder="@Lang.Strings.Code"
                                   @bind="row.QuantityNscCode" @bind:event="oninput" />
                        }
                        else
                        {
                            <input class="form-control form-control-sm" placeholder="@Lang.Strings.ComponentValue"
                                   @bind="row.Value" @bind:event="oninput" />
                        }
                    </div>
                }
            }
            @if (Vm.CompositeCsvFallbackVisible)
            {
                <p class="text-secondary small mb-2">@Lang.Strings.CompositeCsvHint</p>
                <input class="form-control form-control-sm" placeholder="@Lang.Strings.CompositeCsvPlaceholder"
                       @bind="Vm.TypedSearch.CompositeComponentsCsv" @bind:event="oninput" />
            }
            <input class="form-control form-control-sm mt-2 mb-0" placeholder="@Lang.Strings.ModifierLabel"
                   @bind="Vm.TypedSearch.CompositeGroupModifier" @bind:event="oninput" />
        </div>
    }

    @if (Vm.EditorSpecialVisible)
    {
        <div class="border rounded p-2 mb-3">
            <div class="fw-semibold mb-2">@Lang.Strings.Special</div>
            <p class="text-secondary small mb-2">@Lang.Strings.SpecialValueHint</p>
            <input class="form-control form-control-sm mb-2" placeholder="@Lang.Strings.ModifierLabel"
                   @bind="Vm.TypedSearch.SpecialGroupModifier" @bind:event="oninput" />
            <input class="form-control form-control-sm" placeholder="@Lang.Strings.Value"
                   @bind="Vm.TypedSearch.SpecialValue" @bind:event="oninput" />
        </div>
    }

    <button type="button" class="btn btn-outline-primary btn-sm"
            disabled="@Vm.IsLoading"
            @onclick="@(() => Vm.AddTypedSearchClauseCommand.Execute(null))">
        @Lang.Strings.AddTypedClauseToDraft
    </button>
</div>
