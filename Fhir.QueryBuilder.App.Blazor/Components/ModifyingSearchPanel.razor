@inject MainViewModel Vm
@inject QueryBuilderUiLanguageService Lang

<div class="small">
    <div class="fw-semibold mb-3">@Lang.Strings.ModifyingSectionTitle</div>

    <div class="row g-2 mb-2 align-items-center">
        <label class="col-sm-4">_contained</label>
        <div class="col-sm-8">
            <select class="form-select form-select-sm" @bind="Vm.Modifying.ContainedChoice">
                @foreach (var o in Vm.Modifying.ContainedPresetChoices)
                {
                    <option value="@o">@(string.IsNullOrEmpty(o) ? Lang.Strings.UnsetOption : o)</option>
                }
            </select>
        </div>
        <label class="col-sm-4">_containedType</label>
        <div class="col-sm-8">
            <select class="form-select form-select-sm" @bind="Vm.Modifying.ContainedTypeChoice">
                @foreach (var o in Vm.Modifying.ContainedTypePresetChoices)
                {
                    <option value="@o">@(string.IsNullOrEmpty(o) ? Lang.Strings.UnsetOption : o)</option>
                }
            </select>
        </div>
        <label class="col-sm-4">_count</label>
        <div class="col-sm-8">
            <input class="form-control form-control-sm" placeholder="@Lang.Strings.PaginationCount" @bind="Vm.Modifying.CountValue" @bind:event="oninput" />
        </div>
        <label class="col-sm-4">_maxresults</label>
        <div class="col-sm-8">
            <input class="form-control form-control-sm" placeholder="@Lang.Strings.MaxResultsInBundle" @bind="Vm.Modifying.MaxResultsValue" @bind:event="oninput" />
        </div>
        <label class="col-sm-4">_summary</label>
        <div class="col-sm-8">
            <select class="form-select form-select-sm" @bind="Vm.Modifying.SummaryChoice">
                @foreach (var o in Vm.Modifying.SummaryPresetChoices)
                {
                    <option value="@o">@(string.IsNullOrEmpty(o) ? Lang.Strings.UnsetOption : o)</option>
                }
            </select>
        </div>
    </div>

    <hr />

    <div class="fw-semibold mb-2">@Lang.Strings.ElementsSortSection</div>
    <select class="form-select form-select-sm mb-2" @bind="Vm.Modifying.SelectedElementHint">
        @foreach (var e in Vm.Modifying.ElementChoices)
        {
            <option value="@e">@e</option>
        }
    </select>
    <div class="d-flex flex-wrap gap-2 align-items-center mb-3">
        <div class="form-check m-0">
            <input class="form-check-input" type="checkbox" id="sortDesc"
                   @bind="Vm.Modifying.SortDescendingPrefix" />
            <label class="form-check-label" for="sortDesc">@Lang.Strings.SortPrefixMinus</label>
        </div>
        <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="@(() => Vm.ModifyingAddElementCommand.Execute(null))">@Lang.Strings.AddElements</button>
        <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="@(() => Vm.ModifyingAddSortCommand.Execute(null))">@Lang.Strings.AddSort</button>
    </div>

    <div class="row g-2">
        <div class="col-md-6">
            <div class="text-secondary small mb-1">@Lang.Strings.ElementsList</div>
            <select class="form-select form-select-sm mb-2" size="5">
                @foreach (var x in Vm.Modifying.Elements)
                {
                    <option>@x</option>
                }
            </select>
            <button type="button" class="btn btn-outline-secondary btn-sm w-100" @onclick="@(() => Vm.ModifyingClearElementsCommand.Execute(null))">@Lang.Strings.ClearElements</button>
        </div>
        <div class="col-md-6">
            <div class="text-secondary small mb-1">@Lang.Strings.SortList</div>
            <select class="form-select form-select-sm mb-2" size="5">
                @foreach (var x in Vm.Modifying.SortLines)
                {
                    <option>@x</option>
                }
            </select>
            <button type="button" class="btn btn-outline-secondary btn-sm w-100" @onclick="@(() => Vm.ModifyingClearSortCommand.Execute(null))">@Lang.Strings.ClearSort</button>
        </div>
    </div>

    <button type="button" class="btn btn-outline-secondary btn-sm mt-3" @onclick="@(() => Vm.ModifyingResetFormCommand.Execute(null))">@Lang.Strings.ResetThisPage</button>
</div>
