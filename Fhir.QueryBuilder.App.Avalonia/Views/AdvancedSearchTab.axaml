<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Fhir.QueryBuilder.ViewModels"
             xmlns:adv="using:Fhir.QueryBuilder.AdvancedSearch"
             x:Class="Fhir.QueryBuilder.App.Avalonia.Views.AdvancedSearchTab"
             x:DataType="vm:MainViewModel">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10" Spacing="14">
            <TextBlock FontWeight="SemiBold"
                       Text="Chain parameters" />
            <Grid ColumnDefinitions="*,*,Auto">
                <TextBox Grid.Column="0"
                         Margin="0,0,8,0"
                         Watermark="path (e.g. patient.name)"
                         Text="{Binding Advanced.PendingChainPath}" />
                <TextBox Grid.Column="1"
                         Margin="0,0,8,0"
                         Watermark="value"
                         Text="{Binding Advanced.PendingChainValue}" />
                <Button Grid.Column="2"
                        Content="Add"
                        Command="{Binding TryAddAdvancedChainCommand}" />
            </Grid>
            <ListBox MinHeight="56"
                     ItemsSource="{Binding Advanced.Chains}">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="adv:ChainParameter">
                        <TextBlock>
                            <Run Text="{Binding Path}" />
                            <Run Text=" = " />
                            <Run Text="{Binding Value}" />
                        </TextBlock>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Separator />

            <TextBlock FontWeight="SemiBold"
                       Text="Composite parameters" />
            <Grid ColumnDefinitions="*,*,Auto">
                <TextBox Grid.Column="0"
                         Margin="0,0,8,0"
                         Watermark="parameter name"
                         Text="{Binding Advanced.PendingCompositeName}" />
                <TextBox Grid.Column="1"
                         Margin="0,0,8,0"
                         Watermark="components (comma-separated)"
                         Text="{Binding Advanced.PendingCompositeComponents}" />
                <Button Grid.Column="2"
                        Content="Add"
                        Command="{Binding TryAddAdvancedCompositeCommand}" />
            </Grid>
            <ListBox MinHeight="48"
                     ItemsSource="{Binding Advanced.Composites}">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="adv:CompositeParameter">
                        <TextBlock TextWrapping="Wrap">
                            <Run Text="{Binding ParameterName}" />
                            <Run Text=" ⇒ " />
                            <Run Text="{Binding ComponentsSummary}" />
                        </TextBlock>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Separator />

            <TextBlock FontWeight="SemiBold"
                       Text="_filter expressions" />
            <Grid ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0"
                         Watermark="FHIR filter expression"
                         Text="{Binding Advanced.PendingFilterExpression}" />
                <Button Grid.Column="1"
                        Margin="8,0,0,0"
                        Content="Add"
                        Command="{Binding TryAddAdvancedFilterCommand}" />
            </Grid>
            <ListBox MinHeight="56"
                     ItemsSource="{Binding Advanced.Filters}" />

            <Separator />

            <TextBlock FontWeight="SemiBold"
                       Text="Result control (_count, _offset, _total, _summary, _elements)" />
            <Grid ColumnDefinitions="Auto,*"
                  RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Margin="0,0,10,8"
                           VerticalAlignment="Center"
                           Text="_count" />
                <TextBox Grid.Row="0"
                         Grid.Column="1"
                         Margin="0,0,0,8"
                         Text="{Binding Advanced.ResultCountText}" />
                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Margin="0,0,10,8"
                           VerticalAlignment="Center"
                           Text="_offset" />
                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Margin="0,0,0,8"
                         Text="{Binding Advanced.ResultOffsetText}" />
                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Margin="0,0,10,8"
                           VerticalAlignment="Center"
                           Text="_total" />
                <ComboBox Grid.Row="2"
                          Grid.Column="1"
                          Margin="0,0,0,8"
                          ItemsSource="{Binding TotalModes}"
                          SelectedItem="{Binding Advanced.ResultTotalMode}" />
                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           Margin="0,0,10,8"
                           VerticalAlignment="Center"
                           Text="_summary" />
                <ComboBox Grid.Row="3"
                          Grid.Column="1"
                          Margin="0,0,0,8"
                          ItemsSource="{Binding SummaryModes}"
                          SelectedItem="{Binding Advanced.ResultSummaryMode}" />
                <TextBlock Grid.Row="4"
                           Grid.Column="0"
                           Margin="0,0,10,0"
                           VerticalAlignment="Top"
                           Text="_elements" />
                <TextBox Grid.Row="4"
                         Grid.Column="1"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="48"
                         Watermark="comma-separated element names"
                         Text="{Binding Advanced.ResultElementsCsv}" />
            </Grid>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Clear advanced"
                        Command="{Binding ClearAdvancedSearchCommand}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
